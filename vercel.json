{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm ci --prefix frontend && python -m pip install --break-system-packages -r requirements.txt",
  "buildCommand": "npm run build --prefix frontend",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "functions": {
    "api/index.py": {
      "includeFiles": "frontend/dist/**"
    }
  }
}
